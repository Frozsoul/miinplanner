
rules_version = '2';

service cloud.firestore {
  // Prevent accidental writes to the default database if miinplanner is the target
  match /databases/(default)/documents/{document=**} {
    allow read, write: if false;
  }

  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() && 
             workspaceId != null && 
             exists(/databases/$(database)/documents/workspaces/$(workspaceId)) &&
             request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberUids;
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Allow searching users by email for invitations
      allow list: if isAuthenticated();

      match /taskSpaces/{spaceId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      // Allow read if the user is a member
      allow read: if isAuthenticated() && request.auth.uid in resource.data.memberUids;
      
      // Allow creation if setting self as owner and adding self to members
      allow create: if isAuthenticated() && 
                    request.resource.data.ownerId == request.auth.uid &&
                    request.auth.uid in request.resource.data.memberUids;
      
      // Only the owner can update or delete workspace settings
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Tasks: Collaborative rules
    match /tasks/{taskId} {
      // Logic for reading/listing tasks
      allow read: if isAuthenticated() && (
        // Case 1: Personal task - User is the owner and it's not in a workspace
        (request.query.limit == 0 || (resource.data.get('workspaceId', null) == null && resource.data.userId == request.auth.uid)) ||
        // Case 2: Team task - User is a member of the associated workspace
        (resource.data.get('workspaceId', null) != null && isWorkspaceMember(resource.data.workspaceId))
      );
      
      // Logic for creating tasks
      allow create: if isAuthenticated() && (
        // Personal task
        (request.resource.data.get('workspaceId', null) == null && request.resource.data.userId == request.auth.uid) ||
        // Team task
        (request.resource.data.get('workspaceId', null) != null && isWorkspaceMember(request.resource.data.workspaceId))
      );
      
      // Logic for updating/deleting tasks
      allow update, delete: if isAuthenticated() && (
        // Personal task
        (resource.data.get('workspaceId', null) == null && resource.data.userId == request.auth.uid) ||
        // Team task
        (resource.data.get('workspaceId', null) != null && isWorkspaceMember(resource.data.workspaceId))
      );
    }
  }
}
