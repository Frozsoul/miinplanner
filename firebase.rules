rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getWorkspace(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() && 
             workspaceId != null && 
             exists(/databases/$(database)/documents/workspaces/$(workspaceId)) &&
             request.auth.uid in getWorkspace(workspaceId).memberUids;
    }

    // User Profiles
    match /users/{userId} {
      // Allow any authenticated user to read profiles. 
      // Necessary for team members to identify each other in workspaces.
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      // Allow listing users to support finding teammates by email
      allow list: if isAuthenticated();

      match /taskSpaces/{spaceId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      // Members can read the workspace details
      allow read: if isAuthenticated() && request.auth.uid in resource.data.memberUids;
      
      // Any authenticated user can create a workspace (as long as they are the owner and member)
      allow create: if isAuthenticated() && 
                    request.resource.data.ownerId == request.auth.uid &&
                    request.auth.uid in request.resource.data.memberUids;
      
      // Only the workspace owner can manage its settings or members
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Tasks: Collaborative rules
    match /tasks/{taskId} {
      // Rule 1: Personal Ownership - Access for the creator
      allow read, update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid
      );
      
      // Rule 2: Workspace Membership - Access for any member of the associated workspace
      allow read, update, delete: if isAuthenticated() && 
                                    resource.data.workspaceId != null && 
                                    isWorkspaceMember(resource.data.workspaceId);
      
      // Creation rules - allow if owner OR member of the target workspace
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        (request.resource.data.workspaceId != null && isWorkspaceMember(request.resource.data.workspaceId))
      );
    }
  }
}