
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberUids;
    }

    // User Profiles
    match /users/{userId} {
      // Users can manage their own profile
      allow read, write: if isOwner(userId);
      
      // Allow searching for users by email for workspace invites
      // This is a restricted list operation
      allow list: if isAuthenticated();

      // Personal subcollections (like taskSpaces)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Workspaces
    match /workspaces/{workspaceId} {
      // Allow reading if the user is a member
      allow read: if isAuthenticated() && request.auth.uid in resource.data.memberUids;
      
      // Allow creating a workspace if authenticated and setting self as owner
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      
      // Allow owner to update or delete the workspace
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Tasks: Collaborative rules
    match /tasks/{taskId} {
      // Allow read if owner of the task OR if it belongs to a workspace the user is in
      allow read: if isOwner(resource.data.userId) || 
                  (resource.data.workspaceId != null && isWorkspaceMember(resource.data.workspaceId));
      
      // Allow create if setting self as owner OR if creating in a workspace you are in
      allow create: if isOwner(request.resource.data.userId) || 
                    (request.resource.data.workspaceId != null && isWorkspaceMember(request.resource.data.workspaceId));
      
      // Allow update/delete if owner of the task OR member of the workspace
      allow update, delete: if isOwner(resource.data.userId) || 
                            (resource.data.workspaceId != null && isWorkspaceMember(resource.data.workspaceId));
    }

    // Social Media Posts (Legacy support if still used)
    match /socialMediaPosts/{postId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
